# =============================================
# OpenClaw Environment Configuration Example
# Copy this file to .env and fill in values
# =============================================

# --- Application ---
APP_ENV=production
APP_PORT=8000
SECRET_KEY=REPLACE_ME_generate_with_openssl_rand_hex_32

# --- Database (PostgreSQL) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-this-secure-db-password

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI / LLM ---
OPENAI_API_KEY=sk-...your-openai-api-key-here...

# --- AWS (optional — for S3 artifact storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- Redis (for task queuing / caching) ---
REDIS_URL=redis://redis:6379/0

# --- Nginx / TLS ---
# Set DOMAIN to your EC2 instance's public DNS or a custom domain
DOMAIN=your-ec2-public-dns.compute.amazonaws.com
